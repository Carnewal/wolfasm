# wolfasm unified server — copy to `.env` and adjust per deployment.
# The client derives its ws:// and /dl URLs from the page origin, so you only
# configure the SERVER here; the same wasm build works on any host.

# Listen address. Local dev: ":8080". Behind a TLS-terminating proxy: ":8080".
# Direct TLS (see below): ":443".
WOLFASM_ADDR=:8080

# Directory containing etl.html + etl.js + etl.wasm + etl*.data (the built shell).
WOLFASM_WEBROOT=../etlegacy/build-wasm

# Per-origin pk3 download cache (grows with each server's paks; safe to delete).
WOLFASM_CACHE=./dlcache

# Optional: terminate TLS directly in the server (otherwise front it with a
# reverse proxy / load balancer that terminates TLS). For play.wolfasm.com you
# typically terminate TLS at the proxy and leave these blank.
#WOLFASM_TLS_CERT=/etc/letsencrypt/live/play.wolfasm.com/fullchain.pem
#WOLFASM_TLS_KEY=/etc/letsencrypt/live/play.wolfasm.com/privkey.pem

# Optional: public host, for log output only (e.g. play.wolfasm.com).
#WOLFASM_PUBLIC_HOST=play.wolfasm.com

# Optional: verbose per-packet relay logging (noisy; slows big downloads).
#WOLFASM_VERBOSE=1

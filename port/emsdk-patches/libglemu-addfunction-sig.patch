+      // --- ET:Legacy wasm port fix -------------------------------------------
+      // In a MAIN_MODULE build, a SIDE_MODULE that imports any of the GL
+      // functions reassigned above hits reportUndefinedSymbols -> addFunction,
+      // which (under ASSERTIONS) requires the function to carry a `.sig`. The
+      // GLEmulation.init() block above preserves sigs via copySigs(); this
+      // setupHooks() block predates that and dropped them, aborting boot with
+      // "Missing signature argument to addFunction". Restore the sigs from the
+      // saved originals, with GL-correct fallbacks for the fixed-function
+      // glTexEnv* wrappers (which have no real WebGL/GLES2 original).
+      var __emsPortSig = (fn, emfn, saved, fallback) => {
+        var s = (saved && saved.sig) || fallback;
+        if (fn) fn.sig = s;
+        if (emfn) emfn.sig = s;
+      };
+      __emsPortSig(_glActiveTexture, _emscripten_glActiveTexture, glActiveTexture, 'vi');

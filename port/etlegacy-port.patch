+	elseif(CMAKE_SYSTEM MATCHES "OpenBSD*")
 		# backtrace() lives in libexecinfo on the BSDs, not libc
 		target_link_libraries(os_libraries INTERFACE m pthread execinfo)
 		set(LIB_SUFFIX ".mp.obsd.")

diff --git a/src/client/cl_parse.c b/src/client/cl_parse.c
index 9196a0161..57831f914 100644
--- a/src/client/cl_parse.c
+++ b/src/client/cl_parse.c
@@ -969,6 +969,26 @@ void CL_ParseDownload(msg_t *msg)
 
 	if (cls.download.downloadBlock != block)
 	{
+#ifdef __EMSCRIPTEN__
+		// Over the WebSocket->UDP relay an ack can be lost on the bridge->server
+		// UDP hop. When that happens the server keeps re-sending the window of
+		// blocks we already have (block < downloadBlock) while we sit ahead of it.
+		// Our reliable "nextdl" may already be acknowledged, so it is no longer
+		// auto-resent and the transfer deadlocks. Re-issue the ack for our current
+		// position so the server advances. Rate-limit it (every 50ms) to avoid a
+		// reliable-command overflow when a whole window is re-sent at once, and
+		// throttle the log so it doesn't stall the browser console.
+		if (block >= 0 && block < cls.download.downloadBlock && cls.download.downloadBlock > 0)
+		{
+			static int lastReack = 0;
+			if (cls.realtime - lastReack >= 50 || lastReack == 0)
+			{
+				lastReack = cls.realtime;
+				CL_AddReliableCommand(va("nextdl %d", cls.download.downloadBlock - 1));
+			}
+			return;
+		}
+#endif
 		Com_Printf("CL_ParseDownload: Expected block %d, got %d\n", cls.download.downloadBlock, block);
 		return;
 	}

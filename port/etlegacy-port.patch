+/**
+ * @file emscripten_gl_shim.c
+ * @brief Fixed-function GL entry points that ET:L's GLES1 renderer uses but
+ *        that Emscripten's LEGACY_GL_EMULATION does not provide.
+ *
+ * WebGL has no user clip planes, so glClipPlanef is a no-op here. The effect
+ * is that portal/mirror surfaces are not hard-clipped by the near plane; the
+ * rest of the scene renders normally.
+ */
+
+#ifdef __EMSCRIPTEN__
+
+typedef unsigned int GLenum;
+typedef float        GLfloat;
+
+void glClipPlanef(GLenum plane, const GLfloat *equation)
+{
+	(void)plane;
+	(void)equation;
+}
+
+#endif /* __EMSCRIPTEN__ */
diff --git a/src/sys/net_emscripten.c b/src/sys/net_emscripten.c
new file mode 100644
index 000000000..6875fef74
--- /dev/null
+++ b/src/sys/net_emscripten.c
@@ -0,0 +1,238 @@
+/**
+ * @file net_emscripten.c
+ * @brief WebSocket transport for the browser build's networking.
+ *
+ * The browser has no UDP. This module tunnels ET datagrams over a single
+ * WebSocket to a companion bridge (bridge/etl-ws-bridge.js) that performs the
+ * real UDP send/recv against live ET servers.
+ *
+ * Wire protocol (must match etl-ws-bridge.js):
+ *   [4 bytes IPv4][2 bytes port big-endian][payload]
+ *
+ * net_ip.c calls into the small C API declared at the bottom under
+ * __EMSCRIPTEN__: NET_EMS_Init / NET_EMS_Send / NET_EMS_Recv.
+ */
+
+#ifdef __EMSCRIPTEN__
+
+#include <string.h>
+#include <stdio.h>
+#include <emscripten/websocket.h>
+
+#define NET_EMS_MAXPACKET 2048
+#define NET_EMS_QUEUE     8192  // power of two; large enough to buffer pk3 download floods
+
+typedef struct
+{
+	unsigned char  ip[4];
+	unsigned short port;
+	int            len;
+	unsigned char  data[NET_EMS_MAXPACKET];
+} net_ems_packet_t;
+
+// Incoming ring buffer (filled by the WS onmessage callback, drained by NET_GetPacket).
+static net_ems_packet_t s_rx[NET_EMS_QUEUE];
+static volatile int     s_rxHead = 0; // next write slot
+static volatile int     s_rxTail = 0; // next read slot
+
+// Outgoing queue for datagrams produced before the socket is OPEN.
+static net_ems_packet_t s_txPending[NET_EMS_QUEUE];
+static int              s_txHead = 0;
+static int              s_txTail = 0;
+
+static EMSCRIPTEN_WEBSOCKET_T s_sock  = 0;
+static int                    s_open  = 0;
+
+static void NET_EMS_RawSend(const net_ems_packet_t *p)
+{
+	unsigned char frame[6 + NET_EMS_MAXPACKET];
+	int           n = p->len;
+
+	if (n < 0 || n > NET_EMS_MAXPACKET)
+	{
+		return;
+	}
+	frame[0] = p->ip[0];
+	frame[1] = p->ip[1];
+	frame[2] = p->ip[2];
+	frame[3] = p->ip[3];
+	frame[4] = (unsigned char)(p->port >> 8);
+	frame[5] = (unsigned char)(p->port & 0xff);
+	memcpy(frame + 6, p->data, n);
+	emscripten_websocket_send_binary(s_sock, frame, 6 + n);
+}
+
+static void NET_EMS_FlushOpen(void)
+{
+	s_open = 1;
+	// Flush anything queued before the connection came up.
+	while (s_txTail != s_txHead)
+	{
+		NET_EMS_RawSend(&s_txPending[s_txTail]);
+		s_txTail = (s_txTail + 1) & (NET_EMS_QUEUE - 1);
+	}
+}
+
+static EM_BOOL NET_EMS_OnOpen(int eventType, const EmscriptenWebSocketOpenEvent *e, void *userData)
+{
+	(void)eventType; (void)e; (void)userData;
+	printf("NET_EMS: bridge WebSocket open\n");
+	NET_EMS_FlushOpen();
+	return EM_TRUE;
+}
+
+static EM_BOOL NET_EMS_OnMessage(int eventType, const EmscriptenWebSocketMessageEvent *e, void *userData)
+{
+	(void)eventType; (void)userData;
+	int next;
+
+	if (e->isText || e->numBytes < 6)
+	{
+		return EM_TRUE;
+	}
+
+	next = (s_rxHead + 1) & (NET_EMS_QUEUE - 1);
+	if (next == s_rxTail)
+	{
+		return EM_TRUE; // queue full, drop (ET protocol tolerates loss)
+	}
+
+	{
+		net_ems_packet_t *p = &s_rx[s_rxHead];
+		int              payload = e->numBytes - 6;
+		if (payload > NET_EMS_MAXPACKET)
+		{
+			payload = NET_EMS_MAXPACKET;
+		}
+		p->ip[0] = e->data[0];
+		p->ip[1] = e->data[1];
+		p->ip[2] = e->data[2];
+		p->ip[3] = e->data[3];
+		p->port  = (unsigned short)((e->data[4] << 8) | e->data[5]);
+		p->len   = payload;
+		memcpy(p->data, e->data + 6, payload);
+		s_rxHead = next;
+	}
+	return EM_TRUE;
+}
+
+static EM_BOOL NET_EMS_OnError(int eventType, const EmscriptenWebSocketErrorEvent *e, void *userData)
+{
+	(void)eventType; (void)e; (void)userData;
+	return EM_TRUE;
+}
+
+static EM_BOOL NET_EMS_OnClose(int eventType, const EmscriptenWebSocketCloseEvent *e, void *userData)
+{
+	(void)eventType; (void)e; (void)userData;
+	s_open = 0;
+	return EM_TRUE;
+}
+
+/**
+ * @brief Open the WebSocket bridge connection.
+ * @param[in] url e.g. "ws://localhost:9000/"
+ */
+void NET_EMS_Init(const char *url)
+{
+	EmscriptenWebSocketCreateAttributes attr;
+
+	if (s_sock)
+	{
+		return; // already initialised
+	}
+	if (!emscripten_websocket_is_supported())
+	{
+		printf("NET_EMS_Init: WebSockets not supported in this environment\n");
+		return;
+	}
+
+	emscripten_websocket_init_create_attributes(&attr);
+	attr.url      = url;
+	attr.protocols = "binary";
+
+	s_sock = emscripten_websocket_new(&attr);
+	if (s_sock <= 0)
+	{
+		printf("NET_EMS_Init: failed to create WebSocket to %s\n", url);
+		s_sock = 0;
+		return;
+	}
+
+	emscripten_websocket_set_onopen_callback(s_sock, NULL, NET_EMS_OnOpen);
+	emscripten_websocket_set_onmessage_callback(s_sock, NULL, NET_EMS_OnMessage);
+	emscripten_websocket_set_onerror_callback(s_sock, NULL, NET_EMS_OnError);
+	emscripten_websocket_set_onclose_callback(s_sock, NULL, NET_EMS_OnClose);
+
+	// Guard against a race where the socket is already OPEN by the time the
+	// onopen callback is registered (can happen with a local bridge).
+	{
+		unsigned short state = 0;
+		emscripten_websocket_get_ready_state(s_sock, &state);
+		if (state == 1 /* OPEN */)
+		{
+			NET_EMS_FlushOpen();
+		}
+	}
+
+	printf("NET_EMS_Init: connecting to bridge %s\n", url);
+}
+
+/**
+ * @brief Tunnel one datagram to ip:port via the bridge.
+ */
+void NET_EMS_Send(const unsigned char ip[4], unsigned short port, const void *data, int len)
+{
+	net_ems_packet_t pkt;
+
+	if (!s_sock || len < 0 || len > NET_EMS_MAXPACKET)
+	{
+		return;
+	}
+	pkt.ip[0] = ip[0]; pkt.ip[1] = ip[1]; pkt.ip[2] = ip[2]; pkt.ip[3] = ip[3];
+	pkt.port  = port;
+	pkt.len   = len;
+	memcpy(pkt.data, data, len);
+
+	if (s_open)
+	{
+		NET_EMS_RawSend(&pkt);
+	}
+	else
+	{
+		int next = (s_txHead + 1) & (NET_EMS_QUEUE - 1);
+		if (next != s_txTail)
+		{
+			s_txPending[s_txHead] = pkt;
+			s_txHead              = next;
+		}
+	}
+}
+
+/**
+ * @brief Pop one received datagram.
+ * @return payload length, or -1 if none queued.
+ */
+int NET_EMS_Recv(unsigned char ip[4], unsigned short *port, void *buf, int maxlen)
+{
+	net_ems_packet_t *p;
+	int              n;
+
+	if (s_rxTail == s_rxHead)
+	{
+		return -1;
+	}
+	p = &s_rx[s_rxTail];
+	n = p->len;
+	if (n > maxlen)
+	{
+		n = maxlen;
+	}
+	ip[0] = p->ip[0]; ip[1] = p->ip[1]; ip[2] = p->ip[2]; ip[3] = p->ip[3];
+	*port = p->port;
+	memcpy(buf, p->data, n);
+	s_rxTail = (s_rxTail + 1) & (NET_EMS_QUEUE - 1);
+	return n;
+}
+
+#endif /* __EMSCRIPTEN__ */

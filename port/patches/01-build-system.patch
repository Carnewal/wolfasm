+			target_include_directories(renderer_gles_libraries INTERFACE ${GLES_INCLUDE_DIR})
+		endif()
 	endif()
 
 	if(FEATURE_RENDERER_VULKAN)
@@ -233,6 +238,10 @@ if(BUILD_CLIENT OR BUILD_SERVER)
 		target_sources(engine_libraries INTERFACE "${SRC}/qcommon/dl_main_curl.c")
 	elseif(ANDROID)
 		target_sources(engine_libraries INTERFACE "${SRC}/qcommon/dl_main_android.c")
+	elseif(EMSCRIPTEN)
+		# Browser HTTP downloads are proxied through the WebSocket bridge's /dl
+		# endpoint (no libcurl, and cross-origin fetch is blocked by CORS).
+		target_sources(engine_libraries INTERFACE "${SRC}/sys/dl_emscripten.c")
 	else()
 		target_sources(engine_libraries INTERFACE "${SRC}/qcommon/dl_main_stubs.c")
 	endif()
diff --git a/emscripten_build.ps1 b/emscripten_build.ps1
new file mode 100644
index 0000000..0baf44b
--- /dev/null
+++ b/emscripten_build.ps1
@@ -0,0 +1,13 @@
+# Build the ET:Legacy WebAssembly client. Pass a target as $args[0] (default: all).
+$m=[System.Environment]::GetEnvironmentVariable("Path","Machine")
+$u=[System.Environment]::GetEnvironmentVariable("Path","User")
+$env:Path="$m;$u"
+$env:EMSDK_QUIET=1
+. "C:\Users\carnewal\Documents\wolfasm\emsdk\emsdk_env.ps1" | Out-Null
+Set-Location "C:\Users\carnewal\Documents\wolfasm\etlegacy"
+$target = if ($args.Count -gt 0) { $args[0] } else { "" }
+if ($target) {
+  cmake --build build-wasm --target $target -j 8
+} else {
+  cmake --build build-wasm -j 8
+}

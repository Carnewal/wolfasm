diff --git a/cmake/ETLEmscripten.cmake b/cmake/ETLEmscripten.cmake
new file mode 100644
index 0000000..9a842e4
--- /dev/null
+++ b/cmake/ETLEmscripten.cmake
@@ -0,0 +1,130 @@
+#-----------------------------------------------------------------
+# Emscripten / WebAssembly build support
+#
+# Replaces cmake/ETLBundledLibs.cmake for the EMSCRIPTEN target.
+# Instead of building the bundled libs via ExternalProject, we back the
+# `bundled_*` ghost targets with Emscripten ports (SDL2, zlib, libjpeg)
+# and a couple of tiny vendored static libs (minizip, cJSON).
+#-----------------------------------------------------------------
+
+message(STATUS "Configuring bundled libraries for Emscripten (ports + vendored)")
+
+# Dynamic linking (MAIN_MODULE engine + SIDE_MODULE mods) requires every object
+# — engine, mods, and all bundled static libs — to be position independent.
+set(CMAKE_POSITION_INDEPENDENT_CODE ON)
+set(CMAKE_C_FLAGS "${CMAKE_C_FLAGS} -fPIC")
+set(CMAKE_CXX_FLAGS "${CMAKE_CXX_FLAGS} -fPIC")
+
+# Match the mod filenames (cgame.mp.<ARCH>.wasm) to what the engine's
+# Sys_GetDLLName builds from ARCH_STRING ("wasm32", see q_platform.h).
+set(ARCH "wasm32")
+
+set(EMS_LIBS_DIR "${CMAKE_SOURCE_DIR}/libs")
+
+#-----------------------------------------------------------------
+# Emscripten port flags (needed at BOTH compile and link time)
+#-----------------------------------------------------------------
+# SDL2
+add_library(bundled_sdl_int INTERFACE)
+target_compile_options(bundled_sdl_int INTERFACE "-sUSE_SDL=2")
+target_link_options(bundled_sdl_int INTERFACE "-sUSE_SDL=2")
+
+# zlib
+add_library(bundled_zlib INTERFACE)
+target_compile_options(bundled_zlib INTERFACE "-sUSE_ZLIB=1")
+target_link_options(bundled_zlib INTERFACE "-sUSE_ZLIB=1")
+
+# libjpeg
+add_library(bundled_jpeg_int INTERFACE)
+target_compile_options(bundled_jpeg_int INTERFACE "-sUSE_LIBJPEG=1")
+target_link_options(bundled_jpeg_int INTERFACE "-sUSE_LIBJPEG=1")
+
+#-----------------------------------------------------------------
+# minizip (vendored static lib) - pk3 (zip) reading
+#-----------------------------------------------------------------
+add_library(bundled_minizip STATIC
+	"${EMS_LIBS_DIR}/minizip/ioapi.c"
+	"${EMS_LIBS_DIR}/minizip/unzip.c"
+	"${EMS_LIBS_DIR}/minizip/zip.c"
+)
+target_include_directories(bundled_minizip PUBLIC "${EMS_LIBS_DIR}/minizip")
+# minizip needs zlib.h (from the zlib port) at compile time
+target_compile_options(bundled_minizip PRIVATE "-sUSE_ZLIB=1")
+target_link_libraries(bundled_minizip PUBLIC bundled_zlib)
+set_target_properties(bundled_minizip PROPERTIES FOLDER ${BUNDLED_TARGETS_FOLDER})
+
+#-----------------------------------------------------------------
+# cJSON (vendored static lib)
+#-----------------------------------------------------------------
+add_library(bundled_cjson STATIC
+	"${EMS_LIBS_DIR}/cjson/cJSON.c"
+)
+# engine's json wrapper includes <cjson/cJSON.h>, so expose the libs root
+target_include_directories(bundled_cjson PUBLIC "${EMS_LIBS_DIR}")
+
+#-----------------------------------------------------------------
+# sqlite3 (vendored static lib) - used by FEATURE_DBMS / rating / prestige
+#-----------------------------------------------------------------
+add_library(bundled_sqlite3 STATIC
+	"${EMS_LIBS_DIR}/sqlite3/src/sqlite3.c"
+)
+target_include_directories(bundled_sqlite3 PUBLIC "${EMS_LIBS_DIR}/sqlite3/src")
+target_compile_definitions(bundled_sqlite3 PRIVATE
+	SQLITE_THREADSAFE=0
+	SQLITE_OMIT_LOAD_EXTENSION=1
+)
+set_target_properties(bundled_sqlite3 PROPERTIES FOLDER ${BUNDLED_TARGETS_FOLDER})
+# qagame's rating/prestige code uses sqlite directly; ensure it gets the header
+# and lib (stock CMake only links it for the LuaSQL path).
+target_link_libraries(qagame_libraries INTERFACE bundled_sqlite3)
+set_target_properties(bundled_cjson PROPERTIES FOLDER ${BUNDLED_TARGETS_FOLDER})
+
+#-----------------------------------------------------------------
+# Renderer GLES: ET:L's GLES renderer is fixed-function (GLES 1.1). WebGL
+# has no fixed-function pipeline, so we rely on Emscripten's
+# LEGACY_GL_EMULATION (see link flags below) plus a small shim for the few
+# entry points it does not provide (glClipPlanef).
+#-----------------------------------------------------------------
+add_library(bundled_glshim STATIC
+	"${CMAKE_SOURCE_DIR}/src/sys/emscripten_gl_shim.c"
+)
+set_target_properties(bundled_glshim PROPERTIES FOLDER ${BUNDLED_TARGETS_FOLDER})
+# fixed-function symbols are pulled from a static archive, so force whole-archive
+target_link_libraries(renderer_gles_libraries INTERFACE bundled_glshim)
+
+#-----------------------------------------------------------------
+# WebSocket networking transport (browser has no UDP). net_ip.c calls into
+# this; it tunnels ET datagrams to bridge/etl-ws-bridge.js.
+#-----------------------------------------------------------------
+target_sources(engine_libraries INTERFACE "${CMAKE_SOURCE_DIR}/src/sys/net_emscripten.c")
+
+#-----------------------------------------------------------------
+# Global Emscripten link settings for the final executable(s).
+# These are appended to the exe linker flags; per-lib port flags come
+# from the ghost targets above.
+#-----------------------------------------------------------------
+set(ETL_EMS_LINK_FLAGS
+	"-sUSE_SDL=2"
+	"-sUSE_ZLIB=1"
+	"-sUSE_LIBJPEG=1"
+	# ET:L's GLES renderer is fixed-function (GLES 1.1); emulate it on WebGL.
+	"-sLEGACY_GL_EMULATION=1"
+	"-sGL_UNSAFE_OPTS=0"
+	# NOTE: do NOT enable ALLOW_MEMORY_GROWTH — a growable heap yields a
+	# resizable ArrayBuffer, and Chrome's WebGL rejects texture/buffer data
+	# views over resizable buffers ("ArrayBufferView must not be resizable").
+	# Use a large fixed heap instead.
+	"-sINITIAL_MEMORY=2147483648"
+	"-sFORCE_FILESYSTEM=1"
+	"-sSTACK_SIZE=5242880"
+	"-sEXIT_RUNTIME=0"
+	"-sEXPORTED_RUNTIME_METHODS=['ccall','cwrap','FS','callMain']"
+	"-sERROR_ON_UNDEFINED_SYMBOLS=1"
+	"-lidbfs.js"
+	"-lwebsocket.js"
+)
+string(REPLACE ";" " " ETL_EMS_LINK_FLAGS_STR "${ETL_EMS_LINK_FLAGS}")
+set(CMAKE_EXE_LINKER_FLAGS "${CMAKE_EXE_LINKER_FLAGS} ${ETL_EMS_LINK_FLAGS_STR}")
+
+# Emit an HTML shell + JS + WASM
+set(CMAKE_EXECUTABLE_SUFFIX ".html")

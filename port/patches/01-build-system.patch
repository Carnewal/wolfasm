diff --git a/cmake/ETLBuildMod.cmake b/cmake/ETLBuildMod.cmake
index 075dae7..bb849ab 100644
--- a/cmake/ETLBuildMod.cmake
+++ b/cmake/ETLBuildMod.cmake
@@ -20,6 +20,21 @@ function(etl_enforce_linux_mod_no_undefined target_name)
 	endif()
 endfunction()
 
+# Build a VM module as an Emscripten SIDE_MODULE (.wasm) that the MAIN_MODULE
+# engine dlopen()s at runtime. Only vmMain/dllEntry need to be reachable; the
+# module talks to the engine solely through the passed syscall pointer.
+function(etl_emscripten_side_module target_name)
+	if(EMSCRIPTEN)
+		set_target_properties(${target_name} PROPERTIES SUFFIX ".wasm")
+		target_compile_options(${target_name} PRIVATE "-fPIC")
+		target_link_options(${target_name} PRIVATE
+			"-sSIDE_MODULE=1"
+			"-fPIC"
+			"SHELL:-sEXPORTED_FUNCTIONS=['_vmMain','_dllEntry']"
+		)
+	endif()
+endfunction()
+

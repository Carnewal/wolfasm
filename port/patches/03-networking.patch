+// Parse "a.b.c.d" or "a.b.c.d:port" into a NA_IP netadr. Returns qtrue on match.
+// Numeric only: the browser cannot resolve hostnames to real UDP peers, so we
+// keep the real IP in the address instead of an Emscripten virtual IP.
+static qboolean NET_EMS_ParseIPv4(const char *s, netadr_t *a)
+{
+	unsigned int o0, o1, o2, o3, port = 0;
+	int          n;
+
+	n = sscanf(s, "%u.%u.%u.%u:%u", &o0, &o1, &o2, &o3, &port);
+	if (n < 4 || o0 > 255 || o1 > 255 || o2 > 255 || o3 > 255 || port > 65535)
+	{
+		return qfalse;
+	}
+	Com_Memset(a, 0, sizeof(*a));
+	a->type  = NA_IP;
+	a->ip[0] = (byte)o0;
+	a->ip[1] = (byte)o1;
+	a->ip[2] = (byte)o2;
+	a->ip[3] = (byte)o3;
+	a->port  = BigShort((short)port);
+	return qtrue;
+}
+
+// Resolve the handful of ET:Legacy infrastructure hostnames the client uses to
+// their real IPs. The browser cannot DNS-resolve to real UDP peers (Emscripten
+// hands back unusable virtual IPs), so map them here. Game servers are always
+// numeric (from the master's getserversResponse) and go through the parser above.
+static qboolean NET_EMS_ResolveKnownHost(const char *s, netadr_t *a)
+{
+	static const struct { const char *name; const char *ip; unsigned short port; } hosts[] =
+	{
+		{ "master.etlegacy.com", "104.248.140.165", 27950 },
+		{ "motd.etlegacy.com",   "104.248.140.165", 27951 },
+	};
+	char        host[128];
+	const char  *colon = strchr(s, ':');
+	unsigned int port  = 0;
+	size_t       hlen  = colon ? (size_t)(colon - s) : strlen(s);
+	int          i;
+
+	if (hlen >= sizeof(host))
+	{
+		return qfalse;
+	}
+	memcpy(host, s, hlen);
+	host[hlen] = '\0';
+	if (colon)
+	{
+		port = (unsigned int)atoi(colon + 1);
+	}
+
+	for (i = 0; i < (int)(sizeof(hosts) / sizeof(hosts[0])); i++)
+	{
+		if (!Q_stricmp(host, hosts[i].name))
+		{
+			char buf[48];
+			Com_sprintf(buf, sizeof(buf), "%s:%u", hosts[i].ip, port ? port : hosts[i].port);
+			return NET_EMS_ParseIPv4(buf, a);
+		}
+	}
+	return qfalse;
+}
+#endif

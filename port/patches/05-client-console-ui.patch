--- a/src/client/cl_ui.c
+++ b/src/client/cl_ui.c
@@ -1396,7 +1396,17 @@ void CL_InitUI(void)
 	uivm = VM_Create("ui", qtrue, CL_UISystemCalls, VMI_NATIVE);
 	if (!uivm)
 	{
+#ifdef __EMSCRIPTEN__
+		// No native UI module can be dlopen'd in the browser and retail ET
+		// ships no ui.qvm. Rather than abort, keep the engine alive and open

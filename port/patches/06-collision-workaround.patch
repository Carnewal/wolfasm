diff --git a/src/qcommon/cm_load.c b/src/qcommon/cm_load.c
index ee9720a..abfcea6 100644
--- a/src/qcommon/cm_load.c
+++ b/src/qcommon/cm_load.c
@@ -752,7 +752,150 @@ void CM_LoadMap(const char *name, qboolean clientload, unsigned int *checksum)
 	{
 		Q_strncpyz(cm.name, name, sizeof(cm.name));
 	}
+
+#ifdef __EMSCRIPTEN__
+	CM_EMS_BackupLeafs();
+#endif
+}
+
+#ifdef __EMSCRIPTEN__
+// A stray write during client init (the renderer loading the world) overwrites
+// parts of the collision model with drawVert float data — verified: a corrupt
+// cm.leafs[].cluster read back as the bit pattern of a small float (e.g. 0.375).
+// The corruption is not limited to cm.leafs; it can hit any of the trace-critical
+// arrays (planes/brushsides/brushes/nodes/leafs/leafbrushes/leafsurfaces), which
+// made physical collision fail (traces pass through the floor -> fall through the
+// world). Root-causing the wild write needs a wasm memory watchpoint; until then
+// we snapshot every collision array while known-good (right after load) and
+// restore any that a cheap sampled checksum shows has changed, at the top of each
+// trace. The corruption is a one-shot during init, so after it fires once the
+// checksums match again and no copying happens on the hot path.
+//
+// Only the MAP portion of each array is snapshotted (indices [0,numX)); the box
+// hull entries appended after it (BOX_*) are legitimately rewritten per trace.
+
+#define CM_EMS_MAX_ARR 8
+
+typedef struct
+{
+	const char   *name;
+	void         *live;     ///< live array base (never reallocated after load)
+	void         *backup;   ///< malloc'd known-good copy
+	unsigned int  bytes;    ///< size of the map portion
+	unsigned int  sum;      ///< sampled checksum of the known-good copy
+	int           detect;   ///< 1: checksum it for corruption detection; 0: restore-only
+} cm_emsArr_t;
+
+static cm_emsArr_t cm_emsBak[CM_EMS_MAX_ARR];
+static int         cm_emsBakN = 0;
+
+// XOR ~256 spread 32-bit words — cheap, deterministic, catches float overwrites.
+static unsigned int CM_EMS_SampleSum(const void *p, unsigned int bytes)
+{
+	const unsigned int *w = (const unsigned int *)p;
+	unsigned int        n = bytes / 4, step = (n >> 8) + 1, i, s = 0x9e3779b9u ^ bytes;
+
+	for (i = 0; i < n; i += step)
+	{
+		s = (s * 33u) ^ w[i];
+	}
+	return s;
+}
+
+static void CM_EMS_AddArr(const char *name, void *live, unsigned int bytes, int detect)
+{
+	cm_emsArr_t *a;
+
+	if (cm_emsBakN >= CM_EMS_MAX_ARR || !live || bytes == 0)
+	{
+		return;
+	}
+	a         = &cm_emsBak[cm_emsBakN++];
+	a->name   = name;
+	a->live   = live;
+	a->bytes  = bytes;
+	a->detect = detect;
+	a->backup = malloc(bytes);
+	if (a->backup)
+	{
+		memcpy(a->backup, live, bytes);
+		a->sum = CM_EMS_SampleSum(a->backup, bytes);
+	}
+}
+
+/**
+ * @brief Snapshot all trace-critical collision arrays while known-good.
+ */
+void CM_EMS_BackupLeafs(void)
+{
+	int i;
+
+	for (i = 0; i < cm_emsBakN; i++)
+	{
+		if (cm_emsBak[i].backup)
+		{
+			free(cm_emsBak[i].backup);
+		}
+	}
+	cm_emsBakN = 0;
+	Com_Memset(cm_emsBak, 0, sizeof(cm_emsBak));
+
+	// detect=1 arrays are immutable after load, so a checksum change == corruption.
+	// brushes carry a per-trace `checkcount`, so they can't be checksummed; back
+	// them up as restore-only (reverting checkcount is harmless) and restore them
+	// alongside whenever a detected array trips.
+	CM_EMS_AddArr("planes", cm.planes, (unsigned int)cm.numPlanes * sizeof(cplane_t), 1);
+	CM_EMS_AddArr("brushsides", cm.brushsides, (unsigned int)cm.numBrushSides * sizeof(cbrushside_t), 1);
+	CM_EMS_AddArr("nodes", cm.nodes, (unsigned int)cm.numNodes * sizeof(cNode_t), 1);
+	CM_EMS_AddArr("leafs", cm.leafs, (unsigned int)cm.numLeafs * sizeof(cLeaf_t), 1);
+	CM_EMS_AddArr("leafbrushes", cm.leafbrushes, (unsigned int)cm.numLeafBrushes * sizeof(int), 1);
+	CM_EMS_AddArr("leafsurfaces", cm.leafsurfaces, (unsigned int)cm.numLeafSurfaces * sizeof(int), 1);
+	CM_EMS_AddArr("brushes", cm.brushes, (unsigned int)cm.numBrushes * sizeof(cbrush_t), 0);
+
+	Com_Printf("EMSCOL Backup: %i arrays (planes=%i sides=%i brushes=%i nodes=%i leafs=%i lb=%i ls=%i)\n",
+	           cm_emsBakN, cm.numPlanes, cm.numBrushSides, cm.numBrushes, cm.numNodes,
+	           cm.numLeafs, cm.numLeafBrushes, cm.numLeafSurfaces);
+}
+
+/**
+ * @brief Restore any collision array whose sampled checksum no longer matches the
+ * load-time snapshot. Called at the top of every trace / point-contents query.
+ */
+void CM_EMS_RestoreLeafsIfCorrupt(void)
+{
+	static int emsLog = 0;
+	int        i, bad = -1;
+
+	// Detect: only the immutable arrays are checksummed.
+	for (i = 0; i < cm_emsBakN; i++)
+	{
+		cm_emsArr_t *a = &cm_emsBak[i];
+
+		if (a->backup && a->detect && CM_EMS_SampleSum(a->live, a->bytes) != a->sum)
+		{
+			bad = i;
+			break;
+		}
+	}
+	if (bad < 0)
+	{
+		return;
+	}
+	if (emsLog < 12)
+	{
+		emsLog++;
+		Com_Printf("EMSCOL restore: '%s' corrupt -> restoring all %i collision arrays\n", cm_emsBak[bad].name, cm_emsBakN);
+	}
+	// Restore everything (including the restore-only brushes) from the snapshot.
+	for (i = 0; i < cm_emsBakN; i++)
+	{
+		if (cm_emsBak[i].backup)
+		{
+			memcpy(cm_emsBak[i].live, cm_emsBak[i].backup, cm_emsBak[i].bytes);
+		}
+	}
 }
+#endif
 

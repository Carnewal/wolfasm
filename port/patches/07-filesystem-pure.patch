+#ifdef __EMSCRIPTEN__
+/**
+ * @brief Mark the pak containing the server-side cgame/ui module as referenced.
+ *
+ * The browser client loads cgame/ui as loose wasm side-modules, so no pak is
+ * ever flagged FS_CGAME_REF/FS_UI_REF. A pure server (SV_VerifyPaks_f) requires
+ * the first two "cp" checksums to be the cgame and ui pak pure checksums and
+ * rejects a leading '@'. The real mod pak we have (e.g. the legacy pk3) holds
+ * the native cgame/ui binaries, so flag it to report the checksum the server
+ * expects.
+ */
+static void FS_EMS_MarkModRef(const char *const *names, int flag)
+{
+	searchpath_t *search;
+	int          n;
+
+	for (search = fs_searchpaths; search; search = search->next)
+	{
+		if (search->pack && (search->pack->referenced & flag))
+		{
+			return; // already flagged
+		}
+	}
+	for (search = fs_searchpaths; search; search = search->next)
+	{
+		pack_t *pak = search->pack;
+
+		if (!pak)
+		{
+			continue;
+		}
+		for (n = 0; names[n]; n++)
+		{
+			long         hash = FS_HashFileName(names[n], pak->hashSize);
+			fileInPack_t *pf  = pak->hashTable[hash];
+
+			while (pf)
+			{
+				if (!FS_FilenameCompare(pf->name, names[n]))
+				{
+					pak->referenced |= flag;
+					return;
+				}
+				pf = pf->next;
+			}
+		}
+	}
+}
+#endif

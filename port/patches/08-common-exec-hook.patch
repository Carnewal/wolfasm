+#ifdef __EMSCRIPTEN__
+#include <emscripten.h>
+/**
+ * @brief Push a console command into the buffer from JavaScript.
+ *
+ * The browser has no real keyboard focus/pointer-lock automation path for
+ * driving the client, and there is no other way to reach the command buffer of
+ * a running instance. Expose a tiny entry point so the host page can issue
+ * console commands (connect, reconnect, bind, +forward, +attack, ...) via
+ * Module.ccall('ETL_ExecCommand', null, ['string'], [cmd]). Runs on the main
+ * thread (single-threaded wasm), so it is executed on the next Cbuf_Execute.
+ */
+EMSCRIPTEN_KEEPALIVE void ETL_ExecCommand(const char *cmd)
+{
+	if (cmd && cmd[0])
+	{
+		Cbuf_AddText(cmd);
+		Cbuf_AddText("\n");
+	}
+}
+#endif
